# SocialGrowthAI environment
# Copy this file to .env and fill in real values.

# ── Public IP (set automatically by setup_vps.sh) ──
NEXT_PUBLIC_API_URL=http://localhost:8010
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── App ──
DATABASE_URL=sqlite:///data/social_growth.db
REDIRECT_ROOT_TO_FRONTEND=false
USE_ANDROID_EMULATOR=False
PORT=8010

# ── Multi-Provider LLM Config ──
# Provider rotation list (comma-separated, tried in order).
# Each provider needs its own API_KEY, MODEL, and BASE_URL below.
SKYVERN_LLM_PROVIDERS=Groq,OpenRouter,Google,SambaNova,NVIDIA

# ── Groq (best free tier: 30 RPM, 14,400 RPD, vision) ──
# Get a key at https://console.groq.com/keys
SKYVERN_LLM_GROQ_API_KEY=
SKYVERN_LLM_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
SKYVERN_LLM_GROQ_BASE_URL=https://api.groq.com/openai/v1
SKYVERN_LLM_GROQ_RPM_LIMIT=30

# ── OpenRouter (20 RPM, 50 RPD, vision) ──
# Get a key at https://openrouter.ai/keys
SKYVERN_LLM_OPENROUTER_API_KEY=
SKYVERN_LLM_OPENROUTER_MODEL=meta-llama/llama-4-scout:free
SKYVERN_LLM_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SKYVERN_LLM_OPENROUTER_RPM_LIMIT=20

# ── Google AI Studio (10 RPM, 250 RPD, vision) ──
# Get a key at https://aistudio.google.com/apikey
SKYVERN_LLM_GOOGLE_API_KEY=
SKYVERN_LLM_GOOGLE_MODEL=gemini-2.5-flash
SKYVERN_LLM_GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
SKYVERN_LLM_GOOGLE_RPM_LIMIT=10

# ── SambaNova (30 RPM, vision) ──
# Get a key at https://cloud.sambanova.ai/keys
SKYVERN_LLM_SAMBANOVA_API_KEY=
SKYVERN_LLM_SAMBANOVA_MODEL=Meta-Llama-4-Scout-17B-16E-Instruct
SKYVERN_LLM_SAMBANOVA_BASE_URL=https://api.sambanova.ai/v1
SKYVERN_LLM_SAMBANOVA_RPM_LIMIT=30

# ── NVIDIA NIM (40 RPM, vision) ──
# Get a key at https://build.nvidia.com/nim/meta/meta-llama-4-scout-17b-16e-instruct
SKYVERN_LLM_NVIDIA_API_KEY=
SKYVERN_LLM_NVIDIA_MODEL=meta/llama-4-scout-17b-16e-instruct
SKYVERN_LLM_NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
SKYVERN_LLM_NVIDIA_RPM_LIMIT=40

# ── Skyvern rate-limit guards ──
# Minimum seconds between Skyvern tasks to stay under free-tier rate limits.
SKYVERN_INTER_TASK_DELAY=300

# ── Skyvern auth ──
# Auto-generated by init_skyvern_key.sh
SKYVERN_API_KEY=
SKYVERN_API_URL=http://skyvern:8000

# ── OpenRouter (kept for backend planner/classifier/generator) ──
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-4-scout:free
