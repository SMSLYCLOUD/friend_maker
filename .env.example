# SocialGrowthAI environment
# Copy this file to .env and fill in real values.

# ── Public IP (set automatically by setup_vps.sh) ──
NEXT_PUBLIC_API_URL=http://localhost:8010
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── App ──
DATABASE_URL=sqlite:///data/social_growth.db
REDIRECT_ROOT_TO_FRONTEND=false
USE_ANDROID_EMULATOR=False
PORT=8010

# ── OpenRouter (REQUIRED) ──
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE
# Model used for ALL AI calls (Skyvern + backend planner/classifier/generator).
# Skyvern prepends "openrouter/" so use the model name as-is.
# Free models (rate-limited): google/gemma-4-31b-it:free, meta-llama/llama-4-scout:free
# Cheap paid (recommended for testing): google/gemini-2.0-flash-001
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# ── Skyvern rate-limit guards ──
# Minimum seconds between Skyvern tasks to stay under free-tier rate limits.
# Increase to 180 or 300 if you still hit 429 errors.
SKYVERN_INTER_TASK_DELAY=300

# ── Skyvern auth ──
# JWT from ~/.skyvern/credentials.toml (the "cred" field).
# Generate on the VPS with:  skyvern init
SKYVERN_API_KEY=
SKYVERN_API_URL=http://skyvern:8000
