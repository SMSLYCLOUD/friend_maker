# --- CORE SETTINGS ---
APP_NAME=SocialGrowthAI
VERSION=0.1.0
LOG_LEVEL=INFO

# --- SECURITY ---
# Change this to a long random string on your VPS
API_KEY=super-secret-api-key
JWT_SECRET=generate-a-secure-random-secret-here

# --- AI (OPENROUTER) ---
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY_HERE
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- DATABASE ---
# For local/VPS SQLite: sqlite:///data/social_growth.db
DATABASE_URL=sqlite:///data/social_growth.db

# --- NETWORK ---
# Port the API will run on
PORT=8010
# URL of your frontend (e.g., https://your-domain.com or http://localhost:3000)
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- AUTOMATION (ANDROID) ---
USE_ANDROID_EMULATOR=True
# On VPS Docker, use: http://android-emulator:4723/wd/hub
# For local dev mapping, use: http://localhost:4723/wd/hub
ANDROID_EMULATOR_URL=http://android-emulator:4723/wd/hub
